{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd scorecard-app && npm install",
  "buildCommand": "cd scorecard-app && npm run build",
  "outputDirectory": "scorecard-app/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
